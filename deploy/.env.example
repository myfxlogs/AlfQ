# ALFQ Production Environment Variables
# 复制此文件为 .env 并填入生产实际值。
# 此文件不入 git (.gitignore 已配置)。

# ── Database ──
POSTGRES_PASSWORD=
CLICKHOUSE_PASSWORD=
# compose 需要 DATABASE_URL（由 POSTGRES_PASSWORD 拼接）：
# DATABASE_URL=postgres://alfq:${POSTGRES_PASSWORD}@postgres:5432/alfq?sslmode=disable

# ── Redis ──
REDIS_PASSWORD=

# ── NATS ──
NATS_USER=
NATS_PASSWORD=

# ── Vault ──
VAULT_ROOT_TOKEN=

# ── Grafana ──
GRAFANA_ADMIN_PASSWORD=

# ── API Keys ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
