{
  "title": "ALFQ Trading Dashboard",
  "uid": "alfq-trading",
  "panels": [
    {
      "title": "Tick Rate (ticks/s)",
      "type": "graph",
      "targets": [{"expr": "rate(alfq_md_tick_total[1m])"}]
    },
    {
      "title": "Tick Latency p99 (ms)",
      "type": "graph",
      "targets": [{"expr": "histogram_quantile(0.99, rate(alfq_md_tick_latency_bucket[1m]))"}]
    },
    {
      "title": "Orders / minute",
      "type": "graph",
      "targets": [{"expr": "rate(alfq_oms_order_total[1m])"}]
    },
    {
      "title": "Risk Events",
      "type": "stat",
      "targets": [{"expr": "alfq_risk_events_total"}]
    },
    {
      "title": "Factor Eval Rate",
      "type": "graph",
      "targets": [{"expr": "rate(alfq_factor_eval_total[1m])"}]
    },
    {
      "title": "Active Strategies",
      "type": "stat",
      "targets": [{"expr": "alfq_strategy_loaded_count"}]
    }
  ]
}
