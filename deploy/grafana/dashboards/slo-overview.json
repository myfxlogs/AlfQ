{
  "__inputs": [],
  "title": "ALFQ - SLO Overview",
  "description": "四大 SLO 面板：行情延迟 / 订单成功率 / 风控响应 / 数据写入。来自 docs/15 §SLO 规范。",
  "panels": [
    {
      "title": "Tick Latency p99 (target < 50ms)",
      "type": "stat",
      "targets": [{ "expr": "histogram_quantile(0.99, rate(alfq_md_tick_latency_seconds_bucket[5m])) * 1000" }],
      "fieldConfig": {
        "defaults": { "unit": "ms", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 30 }, { "color": "red", "value": 50 }] } }
      },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 }
    },
    {
      "title": "Tick Gap Rate (target < 0.01%)",
      "type": "stat",
      "targets": [{ "expr": "rate(alfq_md_gap_total[1h]) / rate(alfq_md_tick_total[1h]) * 100" }],
      "fieldConfig": {
        "defaults": { "unit": "percent", "decimals": 4, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 0.005 }, { "color": "red", "value": 0.01 }] } }
      },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 }
    },
    {
      "title": "Order Submit p99 (target < 150ms)",
      "type": "stat",
      "targets": [{ "expr": "histogram_quantile(0.99, rate(alfq_order_e2e_latency_seconds_bucket[5m])) * 1000" }],
      "fieldConfig": {
        "defaults": { "unit": "ms", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 150 }] } }
      },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 }
    },
    {
      "title": "Order Success Rate (target > 99.9%)",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(alfq_order_submit_total{result='success'}[5m])) / sum(rate(alfq_order_submit_total[5m])) * 100" }],
      "fieldConfig": {
        "defaults": { "unit": "percent", "decimals": 3, "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 99.9 }, { "color": "green", "value": 99.95 }] } }
      },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 }
    },
    {
      "title": "Tick Latency p50 / p90 / p99",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(alfq_md_tick_latency_seconds_bucket[5m])) * 1000", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.90, rate(alfq_md_tick_latency_seconds_bucket[5m])) * 1000", "legendFormat": "p90" },
        { "expr": "histogram_quantile(0.99, rate(alfq_md_tick_latency_seconds_bucket[5m])) * 1000", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 }
    },
    {
      "title": "Order Submit Latency p50 / p90 / p99",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(alfq_order_e2e_latency_seconds_bucket[5m])) * 1000", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.90, rate(alfq_order_e2e_latency_seconds_bucket[5m])) * 1000", "legendFormat": "p90" },
        { "expr": "histogram_quantile(0.99, rate(alfq_order_e2e_latency_seconds_bucket[5m])) * 1000", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 }
    },
    {
      "title": "Risk Kill Switch Active",
      "type": "stat",
      "targets": [{ "expr": "alfq_risk_killswitch_active" }],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] }, "mappings": [{ "type": "value", "value": "0", "text": "INACTIVE" }, { "type": "value", "value": "1", "text": "ACTIVE" }] }
      },
      "gridPos": { "x": 0, "y": 12, "w": 6, "h": 4 }
    },
    {
      "title": "Risk Breaker Tripped",
      "type": "stat",
      "targets": [{ "expr": "alfq_risk_breaker_state" }],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] } }
      },
      "gridPos": { "x": 6, "y": 12, "w": 6, "h": 4 }
    },
    {
      "title": "CH Write Success Rate (target > 99.99%)",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(alfq_ch_insert_rows_total{status='success'}[5m])) / sum(rate(alfq_ch_insert_rows_total[5m])) * 100" }],
      "fieldConfig": {
        "defaults": { "unit": "percent", "decimals": 4, "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 99.99 }, { "color": "green", "value": 99.999 }] } }
      },
      "gridPos": { "x": 12, "y": 12, "w": 6, "h": 4 }
    },
    {
      "title": "CH Insert Rate",
      "type": "timeseries",
      "targets": [{ "expr": "rate(alfq_ch_insert_rows_total[1m])" }],
      "fieldConfig": { "defaults": { "unit": "rows/s" } },
      "gridPos": { "x": 18, "y": 12, "w": 6, "h": 4 }
    },
    {
      "title": "Risk Events by Severity",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(alfq_risk_event_total{severity='P0'}[5m])", "legendFormat": "P0" },
        { "expr": "rate(alfq_risk_event_total{severity='P1'}[5m])", "legendFormat": "P1" },
        { "expr": "rate(alfq_risk_event_total{severity='P2'}[5m])", "legendFormat": "P2" }
      ],
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 6 }
    },
    {
      "title": "RPC Error Rate by Service",
      "type": "timeseries",
      "targets": [{ "expr": "sum(rate(alfq_rpc_requests_total{code!='OK'}[5m])) by (service) / sum(rate(alfq_rpc_requests_total[5m])) by (service) * 100" }],
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 6 }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["slo", "alfq", "production"]
}
