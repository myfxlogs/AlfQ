{
  "title": "MT Session Hub",
  "uid": "mt-hub",
  "panels": [
    {
      "title": "Active Sessions by Platform",
      "type": "stat",
      "targets": [
        {
          "expr": "mthub_active_sessions",
          "legendFormat": "{{platform}}"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 4 }
    },
    {
      "title": "Session Reconnects",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(mthub_session_reconnect_total[5m])",
          "legendFormat": "{{platform}}/{{reason}}"
        }
      ],
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 4 }
    },
    {
      "title": "RPC Latency (p99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(mthub_rpc_duration_seconds_bucket[5m]))",
          "legendFormat": "{{method}}"
        }
      ],
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 }
    },
    {
      "title": "Order Event Lag",
      "type": "timeseries",
      "targets": [
        {
          "expr": "mthub_order_event_lag_seconds",
          "legendFormat": "lag"
        }
      ],
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 4 }
    }
  ]
}
